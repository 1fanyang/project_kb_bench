{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Baseline Prediction",
  "type": "object",
  "required": ["case_id", "pred_answer", "evidence"],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "pred_answer": {"type": "string"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rank", "path", "source_id", "lines", "text", "score"],
        "properties": {
          "rank": {"type": "integer", "minimum": 1},
          "path": {"type": "string"},
          "source_id": {"type": "string"},
          "lines": {"type": "string"},
          "text": {"type": "string"},
          "score": {"type": "number"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
