{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/kb-benchmark/entity-index.schema.json",
  "title": "Analyzer Entity Index Row",
  "type": "object",
  "required": [
    "entity_id",
    "project",
    "source_id",
    "name",
    "kind",
    "path",
    "line_start",
    "line_end",
    "extractor",
    "confidence"
  ],
  "properties": {
    "entity_id": {"type": "string", "minLength": 1},
    "project": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1},
    "line_start": {"type": "integer", "minimum": 0},
    "line_end": {"type": "integer", "minimum": 0},
    "extractor": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "signature": {"type": "string"},
    "parent_entity_id": {"type": "string"},
    "namespace": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "normalized_name": {"type": "string"},
    "domain_kind": {"type": "string"},
    "summary": {"type": "string"}
  },
  "additionalProperties": true
}
