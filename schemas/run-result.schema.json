{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/kb-benchmark/run-result.schema.json",
  "title": "Benchmark Run Result Row",
  "type": "object",
  "required": ["case_id", "answer"],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "retrieved_contexts": {
      "type": "array",
      "items": {"$ref": "#/$defs/context"}
    },
    "retrieved": {
      "type": "array",
      "items": {"$ref": "#/$defs/context"}
    },
    "contexts": {
      "type": "array",
      "items": {"$ref": "#/$defs/context"}
    },
    "answer": {"type": "string"},
    "pred_answer": {"type": "string"},
    "baseline": {"type": "string"},
    "model": {"type": "string"},
    "prompt_chars": {"type": "integer", "minimum": 0},
    "token_usage": {"$ref": "#/$defs/token_usage"}
  },
  "$defs": {
    "context": {
      "type": "object",
      "properties": {
        "rank": {"type": "integer", "minimum": 1},
        "source_id": {"type": "string"},
        "path": {"type": "string"},
        "lines": {"type": "string"},
        "text": {"type": "string"},
        "score": {"type": "number"}
      },
      "anyOf": [
        {"required": ["source_id"]},
        {"required": ["path"]}
      ],
      "additionalProperties": true
    },
    "token_usage": {
      "type": "object",
      "properties": {
        "source": {"type": "string"},
        "events_seen": {"type": "integer", "minimum": 0},
        "total_token_usage": {"$ref": "#/$defs/token_counts"},
        "last_token_usage": {"$ref": "#/$defs/token_counts"},
        "model_context_window": {"type": ["integer", "null"]}
      },
      "additionalProperties": true
    },
    "token_counts": {
      "type": "object",
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "reasoning_output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
