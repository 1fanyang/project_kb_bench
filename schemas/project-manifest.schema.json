{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/kb-benchmark/project-manifest.schema.json",
  "title": "Benchmark Project Manifest",
  "type": "object",
  "required": ["schema_version", "project", "source_sets", "created_at", "analyzer_version"],
  "properties": {
    "schema_version": {"const": "project-manifest/v1"},
    "project": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string"}
      },
      "additionalProperties": true
    },
    "source_sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "repo_name", "local_root", "source_role", "authority", "available"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "repo_name": {"type": "string", "minLength": 1},
          "local_root": {"type": "string", "minLength": 1},
          "source_role": {"type": "string", "minLength": 1},
          "authority": {"type": "string", "minLength": 1},
          "available": {"type": "boolean"},
          "branch": {"type": "string"},
          "commit": {"type": "string"},
          "snapshot_id": {"type": "string"},
          "content_hash": {"type": "string"},
          "warnings": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "created_at": {"type": "string", "minLength": 1},
    "analyzer_version": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
