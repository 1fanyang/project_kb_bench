.omx/
archive/
# Whitelist: Phase 5 promotion put the historical v1 analyzer bundles
# under runs/archive/ — those should stay tracked so the v1 benchmark
# JSONLs can still lint against them.
!runs/archive/
!runs/archive/**
examples/
dsk
repo_sources/
# Phase 3 signal_emitter integration test ships a small Verilog fixture
# under tests/fixtures/signal_emitter/repo_sources/. Keep the fixture
# tracked even though the path name matches the ignore rule above.
!tests/fixtures/signal_emitter/repo_sources/
!tests/fixtures/signal_emitter/repo_sources/**
__pycache__/
*.py[cod]
.DS_Store
drafts/
runs/baseline_tmp/
runs/v1_2_llm_full/
runs/smoke50_vortex/
runs/smoke50_vortex_run50/
runs/*sample*.jsonl
runs/*lint_ship*.json
runs/*lint_fixes.json
runs/*lint_freshrun.json
runs/*lint_post_fixes.json
runs/lint_v1_1_with_extensions.json
predictions/vortex_grep_parts/

# Analyzer-v2 (Phase 0+) — parse-coverage per-file JSONL and indexing logs.
# Summary JSONs and markdown reports are kept tracked.
#
# Note: tools/codegraph/ USED to be gitignored entirely while the fork was
# local-only. It is now vendored into kb_benchmark (2026-06-30); see
# tools/codegraph/NOTES_kb_benchmark.md. Its own .gitignore handles
# node_modules / dist / tsbuildinfo etc. We keep tools/codegraph-bundle/
# ignored because that was the alternate "standalone installer bundle"
# location that we never used.
tools/codegraph-bundle/
runs/feasibility_v2_analyzer/*.jsonl
runs/feasibility_v2_analyzer/*.log

# uv-managed virtualenv (created by `uv add`).
.venv/
